{
  "name": "ielts-study-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-version.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=ielts-study",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:sm2": "vitest run src/lib/sm2.test.ts"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vitest": "^3.0.5",
    "vite": "^6.0.0",
    "wrangler": "^4.98.0"
  }
}
