# ローカル開発用（1回コピーして値を埋める）
# cp .env.local.example .env.local
#
# 設定画面の初期値として使われます（localStorage が空のときのみ補完）

# ローカル開発（推奨）: 別ターミナルで npm run dev:worker を起動
VITE_DEFAULT_WORKER_URL=http://127.0.0.1:8787

# 本番 Worker を直接叩く場合（secrets:push 済みが必要）:
# VITE_DEFAULT_WORKER_URL=https://ielts-study-worker.byung4050.workers.dev

VITE_DEFAULT_SYNC_TOKEN=
